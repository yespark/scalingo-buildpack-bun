#!/usr/bin/env bash
#
# Installe bun puis `bun install`, et — point crucial — exporte bun sur le PATH
# pour les buildpacks SUIVANTS (le ruby-buildpack lance `assets:precompile` →
# jsbundling `bun run build`). Calqué sur le buildpack bun de proconnect-gouv/
# hyyypertool, mais bun-only (pas de node) et avec le fichier `export`.
#
set -o errexit
set -o pipefail
[ -n "${BUILDPACK_DEBUG:-}" ] && set -x

# Évite une fuite de GIT_DIR depuis une étape de build précédente.
unset GIT_DIR

header() { echo "" ; echo "-----> $*" ; }
info()   { echo "       $*" ; }

BUILD_DIR=${1:-}
CACHE_DIR=${2:-}
# ENV_DIR=${3:-}
BP_DIR=$(cd "$(dirname "${0:-}")"; cd ..; pwd)

# Version lue dans .bun-version : on retire espaces/sauts de ligne et un éventuel
# "v" en préfixe (v3.14 → 3.14) pour fiabiliser la comparaison de cache et l'URL
# d'install. Fichier absent ou vide → "latest".
BUN_VERSION="$(tr -d '[:space:]' 2>/dev/null < "$BUILD_DIR/.bun-version" || echo "latest")"
BUN_VERSION="${BUN_VERSION#v}"
[ -z "$BUN_VERSION" ] && BUN_VERSION="latest"
export BUN_INSTALL="$BUILD_DIR/.bun"

# Installe bun via le script officiel (latest ou version épinglée).
install_bun() {
  if [ "$BUN_VERSION" = "latest" ]; then
    curl -fsSL https://bun.sh/install | bash
  else
    curl -fsSL https://bun.sh/install | bash -s "bun-v${BUN_VERSION}"
  fi
}

#
# 1. Installer bun (réutilise le cache si la version correspond)
#
header "Installing bun ${BUN_VERSION}"
if [ -x "$CACHE_DIR/.bun/bin/bun" ] && [ "$("$CACHE_DIR/.bun/bin/bun" --version 2>/dev/null)" = "$BUN_VERSION" ]; then
  info "Using cached bun ${BUN_VERSION}"
  mkdir -p "$BUN_INSTALL"
  cp -a "$CACHE_DIR/.bun/." "$BUN_INSTALL/"
else
  # Retry réseau : le download du binaire bun se fait DANS le script piped, donc
  # on relance tout le pipeline (pas juste le fetch curl) en cas de hoquet.
  attempt=1
  max_attempts=3
  until install_bun; do
    if [ "$attempt" -ge "$max_attempts" ]; then
      info "bun install failed after ${max_attempts} attempts"
      exit 1
    fi
    info "bun install failed (attempt ${attempt}/${max_attempts}), retrying in 5s..."
    attempt=$((attempt + 1))
    sleep 5
  done
  mkdir -p "$CACHE_DIR/.bun"
  cp -a "$BUN_INSTALL/." "$CACHE_DIR/.bun/"
fi
export PATH="$BUN_INSTALL/bin:$PATH"
info "bun $(bun --version)"

#
# 1b. Expose un `node` (→ bun) sur le PATH. Le ruby-buildpack teste `command -v node`
#     (node_js_preinstalled?) : s'il en trouve un, il SKIP son install de Node par
#     défaut (24.13.0, codée en dur) et le warning « not pinned » associé. Ce `node`
#     n'est jamais exécuté (jsbundling lance `bun run build`, dartsass son binaire).
#     Créé hors du bloc cache → recréé à chaque deploy, y compris sur cache restore.
#
ln -sf bun "$BUN_INSTALL/bin/node"
info "node -> bun (skips ruby-buildpack default Node install + warning)"

#
# 2. Installer les dépendances JS
#
header "Installing JS dependencies (bun install --frozen-lockfile)"
cd "$BUILD_DIR"
bun install --frozen-lockfile

#
# 3. Exporter bun pour les buildpacks SUIVANTS (build-time).
#    Le ruby-buildpack source ce fichier avant de lancer assets:precompile.
#
header "Exporting bun on PATH for subsequent buildpacks"
{
  echo "export BUN_INSTALL=\"$BUILD_DIR/.bun\""
  echo "export PATH=\"$BUILD_DIR/.bun/bin:\$PATH\""
} > "$BP_DIR/export"

#
# 4. PATH runtime (.profile.d sourcé au boot du dyno). Inutile à Rails en soi,
#    mais garde bun disponible dans la console/les process si besoin.
#
mkdir -p "$BUILD_DIR/.profile.d"
{
  echo "export BUN_INSTALL=\"\$HOME/.bun\""
  echo "export PATH=\"\$HOME/.bun/bin:\$PATH\""
} > "$BUILD_DIR/.profile.d/bun.sh"

header "bun buildpack done"
